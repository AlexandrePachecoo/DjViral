# Supabase (server-side: service role key NUNCA vai pro browser)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=clips
SUPABASE_SOURCES_BUCKET=sources

# Worker de análise (Railway)
WORKER_URL=https://seu-worker.up.railway.app
WORKER_SECRET=troque-por-um-segredo-forte

# Autenticação (assina os cookies de sessão). Use um valor longo e aleatório,
# ex.: `openssl rand -hex 32`. Pagamento ainda não implementado.
AUTH_SECRET=troque-por-um-segredo-forte-de-32-bytes
