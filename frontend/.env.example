# Supabase (server-side: service role key NUNCA vai pro browser)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=clips
SUPABASE_SOURCES_BUCKET=sources

# Worker de análise (Railway)
WORKER_URL=https://seu-worker.up.railway.app
WORKER_SECRET=troque-por-um-segredo-forte

# Autenticação (assina os cookies de sessão). Use um valor longo e aleatório,
# ex.: `openssl rand -hex 32`.
AUTH_SECRET=troque-por-um-segredo-forte-de-32-bytes

# Pagamento — AbacatePay (https://app.abacatepay.com → Integração → API keys).
# ABACATEPAY_WEBHOOK_SECRET é o secret que você define ao cadastrar o webhook
# no dashboard, apontando para:
#   https://SEU_SITE/api/webhooks/abacatepay?webhookSecret=MESMO_VALOR_DAQUI
ABACATEPAY_API_KEY=abc_dev_xxxxxxxxxxxx
ABACATEPAY_WEBHOOK_SECRET=troque-por-um-segredo-forte

# Origem pública do site (para as URLs de retorno do checkout). Opcional:
# sem ela, usa a origem da própria requisição.
APP_URL=https://seusite.vercel.app
