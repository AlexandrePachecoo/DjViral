# Credenciais do Supabase (worker usa a service role key)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_BUCKET=clips            # bucket público dos clipes
SOURCES_BUCKET=sources           # bucket privado dos vídeos originais

# Segredo compartilhado com a Vercel para autorizar POST /process
WORKER_SECRET=troque-por-um-segredo-forte

# Parâmetros de processamento (opcionais — estes são os defaults)
MAX_SOURCE_DURATION=10800        # duração máx. do vídeo original (3h); vale p/ YouTube
TOP_N=30
CLIP_DURATION=60
PRE_ROLL=5
MAX_CONCURRENT_JOBS=1            # jobs pesados (process/recut) em paralelo
FFMPEG_THREADS=2                 # threads do x264 por corte (limita a RAM)
OUTPUT_WIDTH=1080                # largura do clipe vertical 9:16 (crop central)
OUTPUT_HEIGHT=1920               # altura do clipe vertical 9:16

# Diretor de IA de visão (opcional): avalia a "vibe" do público via Claude para
# re-ranquear os cortes e dirigir os zooms. A Vercel só pede para planos pagos;
# sem ANTHROPIC_API_KEY, a fase degrada sozinha para a heurística local (YOLO).
ANTHROPIC_API_KEY=                # chave da API da Claude (vazio = IA desligada)
AI_DIRECTOR_ENABLED=true          # liga/desliga a fase de IA no worker
AI_DIRECTOR_MODEL=claude-haiku-4-5   # modelo de visão (haiku=barato; opus=máx qualidade)
AI_DIRECTOR_MAX_CALLS=15          # teto de chamadas à IA por job
AI_DIRECTOR_FRAMES=5              # keyframes enviados por janela
AI_DIRECTOR_BUDGET_SECONDS=180    # teto de tempo da fase de IA por job
AI_DIRECTOR_TIMEOUT=30            # timeout (s) de cada chamada
SCORE_HYPE_WEIGHT=0.35            # peso do hype da IA no score final do corte
