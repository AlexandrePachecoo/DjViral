# Credenciais do Supabase (worker usa a service role key)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_BUCKET=clips            # bucket público dos clipes
SOURCES_BUCKET=sources           # bucket privado dos vídeos originais

# Segredo compartilhado com a Vercel para autorizar POST /process
WORKER_SECRET=troque-por-um-segredo-forte

# Parâmetros de processamento (opcionais — estes são os defaults)
TOP_N=30
CLIP_DURATION=60
PRE_ROLL=5
